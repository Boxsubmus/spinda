{% extends 'base.html.twig' %}

{% block title %}Hyperspin - {{ beatmapset.title }}{% endblock %}

{% block body %}

<div class="flex flex-col shadow">
    {# header #}
    <div class="relative grid overflow-hidden w-full">
        
        {# banner cover #}
        <div class="absolute inset-0 bg-cover bg-center"
            {#style="background-image: url('{{ beatmapset.getBannerUrl(storage) }}');"#}
            >
        </div>

        {# dark overlay so text stays readable #}
        <div class="absolute inset-0" style="background-color: hsla(0, 0%, 0%, 0.2);"></div>

        {# Content #}
        <div class="relative z-10 flex flex-row gap-4 p-4">
            <img class="rounded-lg shadow w-52 h-52" src="{{ beatmapset.getCoverUrl(storage) }}"/>

            <div class="grid content-between text-shadow-lg">
                {# title and artist #}
                <div class="flex flex-col">
                    <p class="text-6xl">{{ beatmapset.title }}</p>
                    <p class="text-4xl">{{ beatmapset.artist }}</p>
                </div>

                {# mapper #}
                <div class="flex items-center gap-2.5">
                    <img class="rounded-lg w-16 shadow" src="{{ beatmapset.author.getAvatarUrl() }}"/>
                    <div class="flex flex-col justify-center">
                        <div>
                            mapped by
                            <a class="font-semibold">{{ beatmapset.author.username }}</a>
                        </div>
                        <p>submitted {{ beatmapset.createdAt|date('F j, Y') }}</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="z-10 flex flex-row p-4 gap-2" style="background-color: hsla(0, 0%, 0%, 0.2);">
            {# Buttons #}
            <twig:ActionButton
                url="{{  path('app_beatmapsets_download', {id: beatmapset.id}) }}"
                label="Download"
                icon="fa-download"
            />

            <twig:ActionButton
                url=""
                label="Feature"
                icon="fa-award"
            />
        </div>
    </div>

    <div class="bg-zinc-800 flex flex-row p-4 gap-2">
    </div>
</div>


{% endblock %}
